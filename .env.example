# Copy this file to .env and fill in real values.
# All variables here are read once at startup by src/core/config.py (Settings).
# Missing/invalid required variables fail fast with one clear error listing
# everything that's wrong, instead of a random crash deep inside whichever
# job happens to run first.

# local | docker | ci | prod -- informational only, not branched on anywhere yet.
ENV=local

# --- Postgres (serving layer) -----------------------------------------------
# Must start with postgresql:// / postgresql+psycopg2:// / postgresql+psycopg://
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- S3 data lake (bronze/silver/gold) --------------------------------------
BUCKET_ID=your-s3-bucket-name

# AWS credentials for boto3 + polars S3 I/O. Either naming works (Settings
# accepts both); AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/AWS_DEFAULT_REGION
# are the boto3/AWS-standard names.
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
AWS_REGION=ca-central-1

# --- Vendor API keys ---------------------------------------------------------
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# https://www.openfigi.com/api -- optional, anonymous calls are rate-limited but work
OPENFIGI_API_KEY=

# --- Misc ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
